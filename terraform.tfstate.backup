            "spot_instance_request_id": "",
            "subnet_id": "subnet-0a6d78d16bbb55b38",
            "tags": {
              "Name": "Jenkins:Ubuntu Linux EC2"
            },
            "tags_all": {
              "Name": "Jenkins:Ubuntu Linux EC2"
            },
            "tenancy": "default",
            "timeouts": null,
            "user_data": "#!/bin/bash\r\n# Log everything for debugging\r\nexec \u003e /var/log/jenkins-install.log 2\u003e\u00261\r\nset -x\r\n\r\necho \"=== Jenkins installation started at $(date) ===\"\r\necho \"=== Running on: $(uname -a) ===\"\r\n\r\n# Update system packages\r\necho \"=== Step 1: System update ===\"\r\ndnf update -y\r\n\r\n# Install Docker\r\necho \"=== Step 2: Installing Docker ===\"\r\ndnf install -y docker\r\nsystemctl enable docker\r\nsystemctl start docker\r\n\r\n# Add ec2-user to docker group\r\nusermod -aG docker ec2-user\r\n\r\n# Install useful tools\r\necho \"=== Step 3: Installing tools ===\"\r\ndnf install -y git wget unzip\r\n\r\n# Create Jenkins data directory with proper permissions\r\necho \"=== Step 4: Setting up Jenkins data directory ===\"\r\nmkdir -p /var/jenkins_home\r\nchown -R 1000:1000 /var/jenkins_home\r\n\r\n# Pull and run Jenkins LTS container\r\necho \"=== Step 5: Starting Jenkins container ===\"\r\ndocker run -d \\\r\n  --name jenkins \\\r\n  --restart unless-stopped \\\r\n  -p 8080:8080 \\\r\n  -p 50000:50000 \\\r\n  -v /var/jenkins_home:/var/jenkins_home \\\r\n  -e JENKINS_HOME=/var/jenkins_home \\\r\n  jenkins/jenkins:lts-jdk21\r\n\r\n# Wait for Jenkins to start and generate the initial password\r\necho \"=== Step 6: Waiting for Jenkins to initialize (up to 3 minutes) ===\"\r\nfor i in $(seq 1 18); do\r\n  sleep 10\r\n  echo \"Attempt $i: checking for Jenkins password...\"\r\n  if docker exec jenkins test -f /var/jenkins_home/secrets/initialAdminPassword 2\u003e/dev/null; then\r\n    echo \"=== Jenkins is ready! ===\"\r\n    echo \"PASSWORD: $(docker exec jenkins cat /var/jenkins_home/secrets/initialAdminPassword)\"\r\n    break\r\n  fi\r\n  echo \"Not ready yet, waiting...\"\r\ndone\r\n\r\n# Install Terraform\r\necho \"=== Step 7: Installing Terraform ===\"\r\nTF_VERSION=\"1.9.8\"\r\nwget -q \"https://releases.hashicorp.com/terraform/${TF_VERSION}/terraform_${TF_VERSION}_linux_amd64.zip\" \\\r\n  -O /tmp/terraform.zip\r\nunzip -o /tmp/terraform.zip -d /tmp/\r\nmv /tmp/terraform /usr/local/bin/\r\nchmod +x /usr/local/bin/terraform\r\nrm /tmp/terraform.zip\r\nterraform version\r\n\r\n# Final status\r\necho \"=== Installation complete at $(date) ===\"\r\necho \"=== Docker containers: ===\"\r\ndocker ps\r\necho \"=== Jenkins password ===\"\r\ndocker exec jenkins cat /var/jenkins_home/secrets/initialAdminPassword || echo \"Jenkins still initializing\"\r\n",
            "user_data_base64": null,
